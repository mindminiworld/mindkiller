-- ฟังก์ชัน Refresh List ผู้เล่น
local function refreshLists()
    for _, child in pairs(PageTarget:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") then child:Destroy() end
    end
    for _, child in pairs(PageSpectate:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") then child:Destroy() end
    end

    local lockLabel = Instance.new("TextLabel", PageTarget)
    lockLabel.Size = UDim2.new(1, 0, 0, 25)
    lockLabel.BackgroundTransparency = 1
    lockLabel.Text = "เลือกชื่อเพื่อพวกโง่ต่อยแม่งเลย"
    lockLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
    lockLabel.Font = Enum.Font.GothamBold
    lockLabel.TextSize = 14

    local ClearLockBtn = Instance.new("TextButton", PageTarget)
    ClearLockBtn.Size = UDim2.new(1, 0, 0, 35)
    ClearLockBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
    ClearLockBtn.Text = "เคลียร์ชื่อพวกโง่"
    ClearLockBtn.TextColor3 = Color3.new(1, 1, 1)
    ClearLockBtn.Font = Enum.Font.GothamBold
    ClearLockBtn.TextSize = 14
    Instance.new("UICorner", ClearLockBtn).CornerRadius = UDim.new(0, 8)
    ClearLockBtn.MouseButton1Click:Connect(function()
        _G.SelectedTargets = {}
        refreshLists()
    end)

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local lockBtn = Instance.new("TextButton", PageTarget)
            lockBtn.Size = UDim2.new(1, 0, 0, 35)
            local isLocked = _G.SelectedTargets[p.UserId]
            lockBtn.BackgroundColor3 = isLocked and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(40, 20, 20)
            lockBtn.Text = (isLocked and "🎯 " or "") .. p.DisplayName
            lockBtn.TextColor3 = Color3.new(1, 1, 1)
            lockBtn.Font = Enum.Font.GothamMedium
            lockBtn.TextSize = 14
            Instance.new("UICorner", lockBtn).CornerRadius = UDim.new(0, 6)
            lockBtn.MouseButton1Click:Connect(function()
                _G.SelectedTargets[p.UserId] = not _G.SelectedTargets[p.UserId]
                refreshLists()
            end)

            local specBtn = Instance.new("TextButton", PageSpectate)
            specBtn.Size = UDim2.new(1, 0, 0, 35)
            local isSpec = (_G.SpectatingPlayer == p)
            specBtn.BackgroundColor3 = isSpec and Color3.fromRGB(200, 80, 40) or Color3.fromRGB(40, 20, 20)
            specBtn.Text = (isSpec and "👁️ " or "") .. p.DisplayName
            specBtn.TextColor3 = Color3.new(1, 1, 1)
            specBtn.Font = Enum.Font.GothamMedium
            specBtn.TextSize = 15
            Instance.new("UICorner", specBtn).CornerRadius = UDim.new(0, 6)
            specBtn.MouseButton1Click:Connect(function()
                if _G.SpectatingPlayer == p then
                    _G.SpectatingPlayer = nil
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("Humanoid") then Camera.CameraSubject = char.Humanoid end
                else
                    _G.SpectatingPlayer = p
                end
                refreshLists()
            end)
        end
    end
end

