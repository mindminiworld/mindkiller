local function createBugDropdown(placeholder, options, globalVarName)
    local container = Instance.new("Frame", PageBug)
    container.Size = UDim2.new(1, 0, 0, 35)
    container.BackgroundTransparency = 1
    container.ClipsDescendants = true
    
    local headerBtn = Instance.new("TextButton", container)
    headerBtn.Size = UDim2.new(1, 0, 0, 35)
    headerBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 55)
    headerBtn.TextColor3 = Color3.new(1, 1, 1)
    headerBtn.Font = Enum.Font.GothamMedium
    headerBtn.TextSize = 13
    headerBtn.Text = "  " .. placeholder .. " 🔽"
    headerBtn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", headerBtn).CornerRadius = UDim.new(0, 6)
    
    local scroll = Instance.new("ScrollingFrame", container)
    scroll.Size = UDim2.new(1, 0, 0, 130)
    scroll.Position = UDim2.new(0, 0, 0, 35)
    scroll.BackgroundColor3 = Color3.fromRGB(15, 25, 40)
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 0 
    scroll.Visible = false

    scroll.MouseEnter:Connect(function() PageBug.ScrollingEnabled = false end)
    scroll.MouseLeave:Connect(function() PageBug.ScrollingEnabled = true end)
    
    local listLayout = Instance.new("UIListLayout", scroll)
    
    local isOpen = false
    headerBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            container.Size = UDim2.new(1, 0, 0, 165)
            scroll.Visible = true
            headerBtn.Text = "  เลือกแล้วปิดหน้าต่าง 🔼"
        else
            container.Size = UDim2.new(1, 0, 0, 35)
            scroll.Visible = false
            PageBug.ScrollingEnabled = true 
            if _G[globalVarName] ~= "" then
                headerBtn.Text = "  " .. _G[globalVarName] .. " 🔽"
            else
                headerBtn.Text = "  " .. placeholder .. " 🔽"
            end
        end
    end)
    
    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton", scroll)
        optBtn.Size = UDim2.new(1, 0, 0, 30)
        optBtn.BackgroundColor3 = Color3.fromRGB(20, 30, 50)
        optBtn.BackgroundTransparency = 0.5
        optBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
        optBtn.Font = Enum.Font.Gotham
        optBtn.TextSize = 12
        optBtn.Text = "  " .. opt.display
        optBtn.TextXAlignment = Enum.TextXAlignment.Left
        
        optBtn.MouseButton1Click:Connect(function()
            _G[globalVarName] = opt.value
            headerBtn.Text = "  " .. opt.value .. " 🔽"
            isOpen = false
            container.Size = UDim2.new(1, 0, 0, 35)
            scroll.Visible = false
            PageBug.ScrollingEnabled = true 
        end)
    end
    scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    end)
end

