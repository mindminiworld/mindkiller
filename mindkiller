-- 🌟 ระบบใหม่: วาร์ปตามหลังคนล็อค + ขยาย Hitbox ซ่อนรูป 🌟
local followConnection = RunService.Heartbeat:Connect(function()
    if _G.AutoFollow then
        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

        if myChar and myHRP then
            for _, targetPlayer in pairs(Players:GetPlayers()) do
                if _G.SelectedTargets[targetPlayer.UserId] then
                    local targetChar = targetPlayer.Character
                    if targetChar then
                        local targetHum = targetChar:FindFirstChild("Humanoid")
                        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")

                        -- ตรวจสอบว่าเป้าหมายยังมีชีวิตอยู่
                        if targetHum and targetHum.Health > 0 and targetHRP then
                            -- ขยาย Hitbox และทำให้ล่องหน
                            targetHRP.Size = Vector3.new(15, 15, 15)
                            targetHRP.Transparency = 1
                            targetHRP.CanCollide = false

                            -- วาร์ปตัวเราไปด้านหลังของเป้าหมายติดๆ (ระยะห่าง 2.5)
                            myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2.5)
                        end
                    end
                end
            end
        end
    end
end)

