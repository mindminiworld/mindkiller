    -- ล้างรายชื่อเก่าออกก่อน
    for _, child in pairs(RightPlayers:GetChildren()) do if child.Name == "PlayerBtn" then child:Destroy() end end
    for _, child in pairs(RightPlayersOP:GetChildren()) do if child.Name == "PlayerBtnOP" then child:Destroy() end end
    for _, child in pairs(PageSpectate:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            -- 1. ระบบล็อคพวกโง่ (แท็บแรก)
            local lockBtn = Instance.new("TextButton", RightPlayers)
            lockBtn.Name = "PlayerBtn"
            lockBtn.Size = UDim2.new(1, 0, 0, 35)
            lockBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 55)
            
            local isLocked = _G.SelectedTargets[p.UserId]
            lockBtn.Text = (isLocked and "🎯 " or "") .. p.DisplayName
            lockBtn.TextColor3 = isLocked and Color3.fromRGB(0, 255, 255) or Color3.new(1, 1, 1)
            lockBtn.Font = Enum.Font.GothamMedium
            lockBtn.TextSize = 13
            Instance.new("UICorner", lockBtn).CornerRadius = UDim.new(0, 6)
            local lockStroke = Instance.new("UIStroke", lockBtn)
            lockStroke.Name = "NeonStroke"
            lockStroke.Color = Color3.fromRGB(0, 255, 255)
            lockStroke.Thickness = 2
            lockStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            lockStroke.Transparency = isLocked and 0 or 1

            lockBtn.MouseButton1Click:Connect(function()
                _G.SelectedTargets[p.UserId] = not _G.SelectedTargets[p.UserId]
                refreshLists()
            end)

            -- 2. ระบบเป้าหมาย OP (แท็บ OP)
            local opBtn = Instance.new("TextButton", RightPlayersOP)
            opBtn.Name = "PlayerBtnOP"
            opBtn.Size = UDim2.new(1, 0, 0, 35)
