-- Tab System
local pages = {}
local tabButtons = {}
local function createTab(name, width)
    local TabBtn = Instance.new("TextButton", TabContainer)
    TabBtn.Size = UDim2.new(0, width or 100, 1, 0)
    TabBtn.BackgroundColor3 = Color3.fromRGB(40, 15, 15)
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.Font = Enum.Font.GothamBold
    TabBtn.TextSize = 13
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 8)

    local Page = Instance.new("ScrollingFrame", ContentArea)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.BorderSizePixel = 0
    Page.ScrollBarThickness = 3
    Page.ScrollBarImageColor3 = Color3.fromRGB(255, 60, 60)
    Page.Visible = false
    Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    
    local PageLayout = Instance.new("UIListLayout", Page)
    PageLayout.Padding = UDim.new(0, 8)

    table.insert(pages, Page)
    table.insert(tabButtons, TabBtn)

    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(pages) do p.Visible = false end
        for _, b in pairs(tabButtons) do 
            b.BackgroundColor3 = Color3.fromRGB(40, 15, 15)
            b.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        Page.Visible = true
        TabBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40)
        TabBtn.TextColor3 = Color3.new(1, 1, 1)
        
        if name == "ล็อคพวกโง่" then
            LeftPanel.Visible = true
            RightPanel.Visible = true
            Page.Parent = RightPanel
        else
            LeftPanel.Visible = false
            RightPanel.Visible = false
            Page.Parent = ContentArea
        end
    end)
    return Page
end

