            opStroke.Color = Color3.fromRGB(255, 50, 50)
            opStroke.Thickness = 2
            opStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            opStroke.Transparency = isOPLocked and 0 or 1

            opBtn.MouseButton1Click:Connect(function()
                _G.OPTargets[p.UserId] = not _G.OPTargets[p.UserId]
                refreshLists()
            end)

            -- 3. ระบบส่องพวกโง่ (อิง Nickname)
            local specBtn = Instance.new("TextButton", PageSpectate)
            specBtn.Size = UDim2.new(1, 0, 0, 35)
            specBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 55)
            
            local isSpec = (_G.SpectatingPlayer == p)
            specBtn.Text = (isSpec and "👁️ " or "") .. p.DisplayName
            specBtn.TextColor3 = isSpec and Color3.fromRGB(0, 255, 255) or Color3.new(1, 1, 1)
