-- ฟังก์ชันถือหมัดและต่อยสำหรับฟาร์มหิน
local function getRockTool()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    if bp and char and char:FindFirstChild("Humanoid") then
        for _, v in pairs(bp:GetChildren()) do
            if v.Name == "Punch" then
                char.Humanoid:EquipTool(v)
            end
        end
    end
    local me = LocalPlayer:FindFirstChild("muscleEvent")
    if me then
        me:FireServer("punch", "leftHand")
        me:FireServer("punch", "rightHand")
    end
end

-- ฟังก์ชันหลักในการฟาร์มหินตาม Durability (ทะลุมิติ)
local function farmRockLoop(durabilityReq, toggleGlobalVar)
    task.spawn(function()
        while task.wait() do
            if not ScreenGui.Parent then break end
            
            if _G[toggleGlobalVar] then
                local char = LocalPlayer.Character
                if LocalPlayer:FindFirstChild("Durability") and LocalPlayer.Durability.Value >= durabilityReq then
                    local machines = workspace:FindFirstChild("machinesFolder")
                    if machines and char and char:FindFirstChild("LeftHand") and char:FindFirstChild("RightHand") then
                        for _, v in pairs(machines:GetDescendants()) do
                            if v.Name == "neededDurability" and v.Value == durabilityReq and v.Parent and v.Parent:FindFirstChild("Rock") then
                                pcall(function()
                                    firetouchinterest(v.Parent.Rock, char.RightHand, 0)
                                    firetouchinterest(v.Parent.Rock, char.RightHand, 1)
                                    firetouchinterest(v.Parent.Rock, char.LeftHand, 0)
                                    firetouchinterest(v.Parent.Rock, char.LeftHand, 1)
                                    getRockTool()
                                end)
                            end
                        end
                    end
                end
            end
        end
    end)
end

