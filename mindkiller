-- LOOP หลัก: จัดการเรื่องถือไอเทม, ต่อย, และ SIZE NAN
task.spawn(function()
    while task.wait(0.05) do
        local char = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        
        if char and char:FindFirstChild("Humanoid") then
            -- ถ้าเปิดปุ่ม "ถือไข่"
            if _G.AutoEquipItems then
                -- 1. สวมใส่ไอเทม
                if backpack then
                    if not char:FindFirstChild("Punch") then
                        local punchTool = backpack:FindFirstChild("Punch")
                        if punchTool then punchTool.Parent = char end 
                    end
                    if not char:FindFirstChild("Protein Egg") then
                        local eggTool = backpack:FindFirstChild("Protein Egg")
                        if eggTool then eggTool.Parent = char end
                    end
                end
                
                -- 2. ปรับ Size เป็น Nan (0/0)
                pcall(function()
                    remotePath:InvokeServer("changeSize", 0/0)
                end)
            end

            -- ถ้าเปิดปุ่ม "ต่อย"
            if _G.AutoPunch then
                if not _G.AutoEquipItems and not char:FindFirstChild("Punch") and backpack then
                    local punchTool = backpack:FindFirstChild("Punch")
                    if punchTool then char.Humanoid:EquipTool(punchTool) end
                end
                if muscleEvent then
                    muscleEvent:FireServer("punch", "leftHand")
                    muscleEvent:FireServer("punch", "rightHand")
                end
            end
        end
    end
end)

