local function refreshLists()
    for _, child in pairs(RightPlayers:GetChildren()) do
        if child.Name == "PlayerBtn" then child:Destroy() end
    end
    for _, child in pairs(PageSpectate:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            -- ปุ่มล็อคเป้า
            local lockBtn = Instance.new("TextButton", RightPlayers)
            lockBtn.Name = "PlayerBtn"
            lockBtn.Size = UDim2.new(1, 0, 0, 35)
            lockBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 55)
            
            local isLocked = _G.SelectedTargets[p.UserId]
            lockBtn.Text = (isLocked and "🎯 " or "") .. p.DisplayName
            lockBtn.TextColor3 = isLocked and Color3.fromRGB(0, 255, 255) or Color3.new(1, 1, 1)
            lockBtn.Font = Enum.Font.GothamMedium
            lockBtn.TextSize = 13
            Instance.new("UICorner", lockBtn).CornerRadius = UDim.new(0, 6)
            
            local lockStroke = Instance.new("UIStroke", lockBtn)
            lockStroke.Name = "NeonStroke"
            lockStroke.Color = Color3.fromRGB(0, 255, 255)
            lockStroke.Thickness = 2
            lockStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            lockStroke.Transparency = isLocked and 0 or 1

            lockBtn.MouseButton1Click:Connect(function()
                _G.SelectedTargets[p.UserId] = not _G.SelectedTargets[p.UserId]
                refreshLists()
            end)

            -- ปุ่มส่อง
            local specBtn = Instance.new("TextButton", PageSpectate)
            specBtn.Size = UDim2.new(1, 0, 0, 35)
            specBtn.BackgroundColor3 = Color3.fromRGB(25, 35, 55)
            
            local isSpec = (_G.SpectatingPlayer == p)
            specBtn.Text = (isSpec and "👁️ " or "") .. p.DisplayName
            specBtn.TextColor3 = isSpec and Color3.fromRGB(0, 255, 255) or Color3.new(1, 1, 1)
            specBtn.Font = Enum.Font.GothamMedium
            specBtn.TextSize = 14
            Instance.new("UICorner", specBtn).CornerRadius = UDim.new(0, 6)
            
            local specStroke = Instance.new("UIStroke", specBtn)
            specStroke.Name = "NeonStroke"
            specStroke.Color = Color3.fromRGB(0, 255, 255)
            specStroke.Thickness = 2
            specStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            specStroke.Transparency = isSpec and 0 or 1

            specBtn.MouseButton1Click:Connect(function()
                if _G.SpectatingPlayer == p then
                    _G.SpectatingPlayer = nil
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("Humanoid") then Camera.CameraSubject = char.Humanoid end
                else
                    _G.SpectatingPlayer = p
                end
                refreshLists()
            end)
        end
    end
end
